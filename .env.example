# Copy to .env and fill in.

# OpenRouter powers the churn-driver analysis step (the only paid call in the pipeline).
OPENROUTER_API_KEY=sk-or-v1-...

# live    = call OpenRouter
# offline = deterministic local analyser, no network, no spend.
#           Used by CI and as the live-demo safety net.
LLM_MODE=live

# Overrides config/platform.yaml -> llm.model_chain[0] when set.
LLM_MODEL=

# sqlite (default, local) | bigquery
WAREHOUSE=sqlite

# Demo knob: fraction of mocked tool calls that fail, to show retry/DLQ behaviour live.
TOOL_FAILURE_INJECTION_RATE=0.0

LOG_LEVEL=INFO
